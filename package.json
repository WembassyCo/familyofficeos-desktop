{
  "name": "familyofficeos-desktop",
  "version": "1.0.0",
  "description": "FamilyOfficeOS Desktop - Cross-platform Electron application for Family Office OS",
  "main": "./out/main/index.js",
  "author": "Wembassy LLC",
  "license": "Proprietary",
  "homepage": "https://wembassy.com",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p src/main && tsc -p src/preload",
    "preview": "vite preview",
    "build:mac": "vite build && tsc -p src/main && tsc -p src/preload && electron-builder --mac",
    "build:win": "vite build && tsc -p src/main && tsc -p src/preload && electron-builder --win",
    "build:linux": "vite build && tsc -p src/main && tsc -p src/preload && electron-builder --linux",
    "test": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "axios": "^1.7.2",
    "better-sqlite3": "^11.1.2",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "electron-updater": "^6.2.1",
    "framer-motion": "^11.2.12",
    "keytar": "^7.9.0",
    "papaparse": "^5.4.1",
    "react-dropzone": "^14.2.3",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-plaid-link": "^3.6.1",
    "recharts": "^2.12.7",
    "tailwindcss": "^3.4.4",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@electron-toolkit/eslint-config-ts": "^1.0.1",
    "@playwright/test": "^1.45.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.9",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.1.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^3.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "postcss": "^8.4.39",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vitest": "^1.6.0"
  },
  "build": {
    "appId": "com.wembassy.familyofficeos",
    "productName": "FamilyOfficeOS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "WembassyCo",
      "repo": "familyofficeos-desktop"
    }
  }
}